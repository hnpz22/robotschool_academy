# robotschool_academy — variables de entorno
# Copiar a .env (NO commitear) y ajustar valores.
# En el VPS, este archivo vive en /opt/robotschool/robotschool_academy/.env (chmod 600).

# -- App ---------------------------------------------------------------
RSAL_ENV=production
RSAL_URL=https://academy.miel-robotschool.com
RSAL_BASE_URL=https://academy.miel-robotschool.com/

# -- Base de datos (la consume el container academy-app vía docker compose) -
DB_HOST=academy-mysql
DB_NAME=robotschool_academy
DB_USER=academy
DB_PASS=cambiar_por_secret_seguro
DB_CHARSET=utf8mb4

# -- MySQL container (academy-mysql) ----------------------------------
MYSQL_ROOT_PASSWORD=cambiar_por_secret_seguro_distinto
MYSQL_DATABASE=robotschool_academy
MYSQL_USER=academy
MYSQL_PASSWORD=cambiar_por_secret_seguro
